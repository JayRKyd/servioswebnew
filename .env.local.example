# Supabase (get these from your Supabase project settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only, never expose

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Feature flags
# Phase 1: false (customer + provider only)
# Phase 2: true  (enables landlord + tenant features)
NEXT_PUBLIC_LANDLORD_TENANT_ENABLED=false

# Algolia Search (OPTIONAL — leave BOTH blank to use Supabase fallback instead)
# If either value is set incorrectly (non-empty but wrong), the app will show
# an "Invalid Application-ID or API key" error on the search page.
# To disable Algolia and use the Supabase fallback: leave both values empty.
# To enable Algolia: get values from https://dashboard.algolia.com → API Keys
#   App ID:       Applications → your app → Settings → App ID
#   Search Key:   API Keys → "Search-Only API Key" (public, read-only — NOT the Admin key)
NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=
ALGOLIA_ADMIN_KEY=   # server-side only — used for indexing sync

# Mapbox (OPTIONAL — map panel is hidden when this is blank)
# Get a public token from https://account.mapbox.com/access-tokens/
# Scope required: styles:read, tiles:read
NEXT_PUBLIC_MAPBOX_TOKEN=

# Google Places (OPTIONAL — enables postcode/address autocomplete in search filters)
# Get from https://console.cloud.google.com → APIs → Places API
# Restrict key to: Places API, Maps JavaScript API; HTTP referrers: your domain
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=

# Sync secret — used to protect the /api/search/sync endpoint
# Set to any random string, same value in apps/api/.env
SYNC_SECRET=your-random-secret

# Website URL (used for Stripe Connect return URLs and auth email redirects)
# Set to your Vercel URL in production: https://servioswebnew.vercel.app
WEB_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
