# Supabase (get these from your Supabase project settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only, never expose

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Feature flags
# Phase 1: false (customer + provider only)
# Phase 2: true  (enables landlord + tenant features)
NEXT_PUBLIC_LANDLORD_TENANT_ENABLED=false

# Algolia Search
# Get these from https://dashboard.algolia.com → API Keys
NEXT_PUBLIC_ALGOLIA_APP_ID=your-algolia-app-id
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=your-search-only-api-key   # public, read-only

# Mapbox
# Get token from https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...

# Sync secret — used to protect the /api/search/sync endpoint
# Set to any random string, same value in apps/api/.env
SYNC_SECRET=your-random-secret

# Website URL (used for Stripe Connect return URLs)
WEB_URL=http://localhost:3000
